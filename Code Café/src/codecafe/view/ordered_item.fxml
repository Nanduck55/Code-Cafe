<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="ordered_item_card" maxWidth="370.0" prefHeight="120.0" prefWidth="370.0" styleClass="ordered_items_card" stylesheets="@../assets/css/orderedItem.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="110.0" prefWidth="348.0" spacing="10">
            <!-- Image -->
            <ImageView fx:id="ordered_image" fitHeight="118.0" fitWidth="103.0" preserveRatio="true">
                <image>
                    <Image url="@../assets/images/Coffee_Based/caramel_macchiato.png" />
                </image>
            <HBox.margin>
               <Insets bottom="-20.0" left="1.0" right="-20.0" top="-5.0" />
            </HBox.margin>
            </ImageView>

            <!-- Text VBox -->
            <VBox prefHeight="110.0" prefWidth="183.0" spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="ordered_name" prefHeight="28.0" prefWidth="277.0" styleClass="ordered_name" text="Caramel Macchiato" wrapText="true">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin></Label>
                <Label fx:id="ordered_prize" styleClass="ordered-prize" text="₱ 00.00" />
                <Text fx:id="ordered_addons" text="Add-ons: Syrup, whipped cream, sinker" wrappingWidth="180.19140625" />
            </VBox>

            <!-- Quantity & Delete -->
            <VBox alignment="TOP_CENTER" prefHeight="110.0" prefWidth="52.0" spacing="5">
                <StackPane styleClass="delete-ordered-item">
                    <ImageView fx:id="delete_ordered_item" fitHeight="32.0" fitWidth="26.0">
                        <image>
                            <Image url="@../assets/images/Icons/trash_icon.png" />
                        </image>
                    </ImageView>
               <VBox.margin>
                  <Insets right="10.0" top="10.0" />
               </VBox.margin>
                </StackPane>
            <StackPane prefHeight="35.0" prefWidth="36.0" />
                <Label fx:id="ordered_name1" graphicTextGap="0.0" prefHeight="25.0" prefWidth="48.0" styleClass="ordered-quantity-item" text="x11" textOverrun="CLIP">
               <font>
                  <Font size="4.0" />
               </font></Label>
            <HBox.margin>
               <Insets />
            </HBox.margin>
            </VBox>
         <StackPane.margin>
            <Insets left="-5.0" />
         </StackPane.margin>
        </HBox>
    </children>
</StackPane>
